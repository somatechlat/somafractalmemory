# Django Security (REQUIRED)
SOMA_SECRET_KEY=change-me-to-secure-random-string
SOMA_ALLOWED_HOSTS=*

# API auth token (required)
SOMA_API_TOKEN=change-me

# API port inside container (host port is mapped via API_PORT)
# SOMA_API_PORT=10101

# Postgres
SOMA_DB_PASSWORD=change-me
SOMA_DB_USER=somafractalmemory
SOMA_DB_NAME=somafractalmemory

# Redis
# SOMA_REDIS_PASSWORD=

# Vault
SOMA_VAULT_TOKEN=change-me

# MinIO (required for Milvus standalone)
SOMA_MINIO_ROOT_USER=change-me
SOMA_MINIO_ROOT_PASSWORD=change-me

# Logging
SOMA_LOG_LEVEL=INFO

# Optional JWT secret (if using JWT)
# SOMA_JWT_SECRET=change-me

# Example: run the standalone stack
# docker compose -f infra/standalone/docker-compose.yml up -d
